#
# Backend ENV (Express + Prisma)
#

# Port server (Railway akan set PORT otomatis)
PORT=4000

# (Opsional) Paksa provider Prisma: postgresql | mysql | sqlite
# Jika kosong, akan auto-detect dari prefix DATABASE_URL:
# - postgresql:// atau postgres://  -> postgresql
# - mysql://                       -> mysql
# - file:                          -> sqlite
DB_PROVIDER="postgresql"

# URL koneksi database (wajib)
# PostgreSQL:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"
#
# MySQL:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DB"
#
# SQLite (dev cepat):
# DATABASE_URL="file:./dev.db"

# Secret untuk JWT (WAJIB diganti untuk production)
JWT_SECRET="change-me"

# CORS origin frontend (wajib untuk frontend beda domain)
# Gunakan URL lengkap dengan scheme (http/https).
CLIENT_ORIGIN="http://localhost:5173"
# Alternatif nama env yang juga didukung:
# CORS_ORIGIN="http://localhost:5173"


